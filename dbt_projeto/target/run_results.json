ricao_feminina.int_recomendacoes_por_fase", "compiled": true, "compiled_code": "with alimentos as (\n    select *\n    from \"nutricao_feminina\".\"main\".\"stg_nutricao_alimentos\"\n),\n\nfases as (\n    select *\n    from \"nutricao_feminina\".\"main\".\"stg_fases_ciclo\"\n),\n\npontuado as (\n    select\n        fases.fase_ciclo,\n        fases.nutriente_prioritario,\n        fases.descricao,\n        alimentos.alimento,\n        case fases.nutriente_prioritario\n            when 'ferro_mg' then alimentos.ferro_mg\n            when 'magnesio_mg' then alimentos.magnesio_mg\n            when 'calcio_mg' then alimentos.calcio_mg\n            when 'zinco_mg' then alimentos.zinco_mg\n        end as valor_nutriente\n    from fases\n    cross join alimentos\n),\n\nrankeado as (\n    select\n        *,\n        row_number() over (\n            partition by fase_ciclo\n            order by valor_nutriente desc\n        ) as ranking\n    from pontuado\n)\n\nselect *\nfrom rankeado", "relation_name": "\"nutricao_feminina\".\"main\".\"int_recomendacoes_por_fase\"", "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-19T00:38:29.184517Z", "completed_at": "2026-06-19T00:38:29.205269Z"}, {"name": "execute", "started_at": "2026-06-19T00:38:29.206335Z", "completed_at": "2026-06-19T00:38:29.206350Z"}], "thread_id": "Thread-1 (worker)", "execution_time": 0.024164438247680664, "adapter_response": {}, "message": null, "failures": null, "unique_id": "test.nutricao_feminina.not_null_stg_nutricao_alimentos_alimento.5defaccbd4", "compiled": true, "compiled_code": "\n    \n    \n\n\n\nselect alimento\nfrom \"nutricao_feminina\".\"main\".\"stg_nutricao_alimentos\"\nwhere alimento is null\n\n\n", "relation_name": null, "batch_results": null}, {"status": "success", "timing": [{"name": "compile", "started_at": "2026-06-19T00:38:29.211383Z", "completed_at": "2026-06-19T00:38:29.230029Z"}, {"name": "execute", "started_at": "2026-06-19T00:38:29.231