        avg(ferro_mg) as ferro_mg,
        avg(zinco_mg) as zinco_mg,
        avg(calcio_mg) as calcio_mg,
        avg(vit_b6_mg) as vit_b6_mg
    from renamed
    group by alimento
)

select *
from deduplicated
  );

